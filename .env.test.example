# Copy to .env.test after `pnpm db:test:up` (supabase start) and fill from its output.
# Playwright loads this so E2E/perf hit the LOCAL Supabase, never your cloud project.

NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
# supabase start prints both keys — paste them here:
NEXT_PUBLIC_PUBLISHABLE_KEY=<anon key from `supabase start`>
SUPABASE_SECRET_KEY=<service_role key from `supabase start`>

# Base URL the tests drive (the Next dev/start server).
BASE_URL=http://localhost:3000

# Demo logins (override only if you seed different credentials).
E2E_OWNER_EMAIL=admin@vayumukhi.in
E2E_OWNER_PASSWORD=farm123
E2E_WORKER_NAME=Suresh
E2E_WORKER_PIN=123456

# Leave ANTHROPIC_API_KEY unset in tests so scan/voice use the offline fallback
# and the suite stays free + deterministic.
