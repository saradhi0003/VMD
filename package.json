{
  "name": "vayumukhi-dairy",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "db:generate": "pnpm --filter @vmd/db generate",
    "db:migrate": "pnpm --filter @vmd/db migrate",
    "db:studio": "pnpm --filter @vmd/db studio",
    "db:seed": "pnpm --filter @vmd/db seed",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "pnpm --filter @vmd/web test:e2e",
    "test:perf": "pnpm --filter @vmd/web test:perf",
    "test:all": "pnpm test && pnpm test:e2e && pnpm test:perf",
    "db:test:up": "supabase start",
    "db:test:reset": "supabase db reset",
    "db:test:seed": "pnpm --filter @vmd/web seed:auth"
  },
  "devDependencies": {
    "@types/node": "^22.7.4",
    "prettier": "^3.3.3",
    "supabase": "^2.107.0",
    "turbo": "^2.1.3",
    "typescript": "^5.6.2",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "supabase",
      "esbuild"
    ]
  }
}
